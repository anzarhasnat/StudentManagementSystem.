<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox fx:id="studentsViewRoot" spacing="18"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.student.controllers.StudentsController">
    <padding><Insets top="35" right="40" bottom="35" left="40"/></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="4">
            <Label text="Student Management" styleClass="title-label"/>
            <Label text="View, search, and manage all enrolled students." styleClass="subtitle-label"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" promptText="Search by Name, ID, Course or Status..."
                   styleClass="glass-text-field" prefWidth="320"/>
        <Button text="Export CSV" styleClass="secondary-button" onAction="#handleExportCSV"/>
        <Button text="+ Add Student" styleClass="primary-button" onAction="#showAddModal"/>
    </HBox>

    <!-- Toolbar -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="editButton" text="✎  Edit Selected" styleClass="secondary-button"
                disable="true" onAction="#showEditModal"/>
        <Button fx:id="deleteButton" text="🗑  Delete Selected"
                style="-fx-background-color: rgba(239,68,68,0.15); -fx-text-fill: #EF4444; -fx-border-color: #EF4444; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 16 8 16; -fx-font-weight: bold;"
                disable="true" onAction="#handleDeleteStudent"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="recordCountLabel" text="Showing 0 records" styleClass="subtitle-label"/>
    </HBox>

    <!-- Table + Profile Side Panel -->
    <HBox VBox.vgrow="ALWAYS" spacing="18">

        <!-- Data Table -->
        <TableView fx:id="studentsTable" HBox.hgrow="ALWAYS" styleClass="glass-table">
            <columns>
                <TableColumn fx:id="colId" text="Student ID" prefWidth="55" visible="false"/>
                <TableColumn fx:id="colFirstName" text="Full Name" prefWidth="150"/>
                <TableColumn fx:id="colLastName" text="Roll Number" prefWidth="120"/>
                <TableColumn fx:id="colAge" text="Branch" prefWidth="120"/>
                <TableColumn fx:id="colCourse" text="Section" prefWidth="150"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="110"/>
                <TableColumn fx:id="colDate" text="Enrolled" prefWidth="120"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>

        <!-- Student Profile Panel (hidden until a row is selected) -->
        <VBox fx:id="profilePanel" prefWidth="280" spacing="0"
              visible="false" managed="false" styleClass="glass-card"
              style="-fx-padding: 0; -fx-background-radius: 16; -fx-border-radius: 16;">

            <!-- Coloured header band -->
            <VBox alignment="CENTER" spacing="8"
                  style="-fx-background-color: linear-gradient(to bottom right, #2563EB, #7C3AED); -fx-background-radius: 16 16 0 0; -fx-padding: 30 20 24 20;">
                <Label text="👤" style="-fx-font-size: 36px;"/>
                <Label fx:id="profileName" text="—"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white; -fx-wrap-text: true; -fx-text-alignment: CENTER;"/>
                <Label fx:id="profileStatusBadge" text="Active"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #10B981; -fx-background-color: rgba(16,185,129,0.2); -fx-background-radius: 20; -fx-padding: 3 14 3 14; -fx-border-color: #10B981; -fx-border-radius: 20; -fx-border-width: 1;"/>
            </VBox>

            <!-- Detail rows -->
            <VBox spacing="14" style="-fx-padding: 20 20 20 20;">
                <VBox spacing="3">
                    <Label text="STUDENT ID" style="-fx-font-size: 10px; -fx-text-fill: #6B7280; -fx-font-weight: bold;"/>
                    <Label fx:id="profileId" text="—" style="-fx-font-size: 14px; -fx-text-fill: white;"/>
                </VBox>
                <VBox spacing="3">
                    <Label text="COURSE" style="-fx-font-size: 10px; -fx-text-fill: #6B7280; -fx-font-weight: bold;"/>
                    <Label fx:id="profileCourse" text="—" style="-fx-font-size: 14px; -fx-text-fill: white; -fx-wrap-text: true;"/>
                </VBox>
                <VBox spacing="3">
                    <Label text="ENROLLMENT DATE" style="-fx-font-size: 10px; -fx-text-fill: #6B7280; -fx-font-weight: bold;"/>
                    <Label fx:id="profileEnrollDate" text="—" style="-fx-font-size: 14px; -fx-text-fill: white;"/>
                </VBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Quick action buttons -->
            <VBox spacing="8" style="-fx-padding: 0 16 16 16;">
                <Button text="✎  Edit This Student" styleClass="primary-button"
                        maxWidth="Infinity" onAction="#showEditModal"/>
                <Button text="🗑  Delete" maxWidth="Infinity"
                        style="-fx-background-color: rgba(239,68,68,0.15); -fx-text-fill: #EF4444; -fx-border-color: #EF4444; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 0 10 0; -fx-font-weight: bold;"
                        onAction="#handleDeleteStudent"/>
            </VBox>
        </VBox>

    </HBox>

    <!-- Pagination Bar -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Rows per page:" styleClass="subtitle-label"/>
        <ComboBox fx:id="pageSizeCombo" prefWidth="75" styleClass="glass-text-field"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="pageInfoLabel" text="Page 1 of 1" styleClass="subtitle-label"/>
        <Button fx:id="firstPageBtn" text="«" styleClass="pagination-button" onAction="#handleFirstPage"/>
        <Button fx:id="prevPageBtn"  text="‹" styleClass="pagination-button" onAction="#handlePrevPage"/>
        <Button fx:id="nextPageBtn"  text="›" styleClass="pagination-button" onAction="#handleNextPage"/>
        <Button fx:id="lastPageBtn"  text="»" styleClass="pagination-button" onAction="#handleLastPage"/>
    </HBox>

</VBox>
